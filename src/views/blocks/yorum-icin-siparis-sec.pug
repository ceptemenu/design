#selectOrderToWriteComment.bottom-modal
    .bottom-modal__divider(onclick='$("#selectOrderToWriteComment").removeClass("active")')
        span
    .bottom-modal-content
        .bottom-modal-content__title(data-i18n="orderSelect.title") Select Order
        p.bottom-modal-content__text(data-i18n="orderSelect.desc") Select the order you want to review below to continue.
        .divider
        .comment-write-select-order
            .order-item-input_wrapper
                input#siparis1(type="radio",name="siparis").order-item-input
                label(for="siparis1").order-item
                    .order-item-image
                        img(src="img/restaruant/gunaydin.jpg")
                        .select_area
                            i.icon.icon-check
                    .order-item-content
                        .order-item-content__title(data-i18n="orderSelect.orderDated") Order Dated October 13, 2020
                        .order-item-content__text
                            span 3x Tea
                            span 1x Magnolia
                            span 2x Chef's Special Pastrami Baked Beans
                            span 1x Water
                        .order-item-content__amount
                            div(data-i18n="common.totalAmount") Total Amount
                            span 123.53 TL
            .order-item-input_wrapper
                input#siparis2(type="radio",name="siparis").order-item-input
                label(for="siparis2").order-item
                    .order-item-image
                        img(src="img/restaruant/gunaydin.jpg")
                        .select_area
                            i.icon.icon-check
                    .order-item-content
                        .order-item-content__title(data-i18n="orderSelect.orderDated") Order Dated October 13, 2020
                        .order-item-content__text
                            span 3x Tea
                            span 1x Magnolia
                            span 2x Chef's Special Pastrami Baked Beans
                            span 3x Tea
                            span 1x Magnolia
                            span 2x Chef's Special Pastrami Baked Beans
                            span 1x Water
                            span 1x Water
                        .order-item-content__amount
                            div(data-i18n="common.totalAmount") Total Amount
                            span 123.53 TL
            .apply-button.button.button--red.button--icon.button--icon--right.mt-20(onclick='$("#selectOrderToWriteComment").removeClass("active");$("#writeComment").addClass("active"); ')
                span(data-i18n="common.continue") Continue
                i.icon.icon-arrow-right
