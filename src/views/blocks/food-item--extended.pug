.food-item.food-item--extended.food-item
    .food-item__image
        img(src="img/food/hamburger.jpg")
    .food-item-content
        .food-item-content-top
            .food-item__title(data-i18n="food.chefsSpecialBurger") Chef's Special Burger
            .food-item__add-cart(onclick='$("#customizeFood").addClass("active")')
                i.icon.icon-plus-square
        .food-item-content-middle
            .food-item__ingredients(data-i18n="food.burgerIngredients")
                | 200g Special Hamburger Patty, Caramelized Onion, French Fries, Tomato, Special Sauce
        .food-item-content-bottom
            .food-item__price 19.90 TL
            .food-item__count.input-button-group
                .button.button--light.button--icon
                    i.icon.icon-chevron-left
                input.input(type="text",value="1")
                .button.button--light.button--icon
                    i.icon.icon-chevron-right
