#bill.bottom-modal.bill
    .bottom-modal__divider(onclick='$("#bill").removeClass("active")')
        span
    .bottom-modal-content
        .bottom-modal-content__title(data-i18n="bill.title") Bill
        p.bottom-modal-content__text(data-i18n="bill.desc") Your orders and products are listed below.
        .renk_turleri
            .renk_turleri-item.red
                span
                p.text(data-i18n="bill.unpaid") Unpaid
            .renk_turleri-item.orange
                span
                p.text(data-i18n="bill.selected") Selected
            .renk_turleri-item.black
                span
                p.text(data-i18n="bill.paid") Paid
        .divider
        .bill-content
            .bill-order
                .button-group.mb-10.d-flex
                    .button.button--light.mr-3(data-i18n="bill.myOrders") My Orders
                    .button.button--red.mt-0(data-i18n="bill.allOrders") All Orders
                .bill-order-header
                    .bill-order-header__title
                        .name.d-flex Muhammet Celepci
                            .status.status--danger.ml-1 +3 Kişi
                        .d-flex.align-items-center
                            .date 05.11.2020
                            .divider.divider-circle
                            .table-no.status.status--danger(data-i18n="bill.table12") Table 12
                .bill-order-content
                    .bill-order-content-header
                        .bill-order-content__title(data-i18n="bill.orderNo") Order No: #257
                            span Sipariş: Muhammet Celepci
                        .button.button--sm.button--red(data-i18n="bill.selectAll") Select All
                    .bill-order-content-items
                        .bill-order-content-item
                            .d-flex
                                .product-count 2
                                .product-name(data-i18n="food.water") Water
                            .product-price 5.00 TL
                        .divider.divider--small
                        .bill-order-content-item.odendi
                            .d-flex
                                .product-count 1
                                .product-name(data-i18n="food.cupOfTea") Cup of Tea
                            .product-price 4.00 TL
                        .divider.divider--small
                        .bill-order-content-item.secildi
                            .d-flex
                                .product-count 8
                                .product-name(data-i18n="food.butterIskender") Butter Iskender
                            .product-price 80.00 TL
                            .secildi-text(data-i18n="bill.itemsSelected") 2 Items Selected
                                include secildi_buttons
                        .bill-order-content-item
                            .d-flex(onclick='$("#odenecek_urun_sayisi").addClass("active")')
                                .product-count 1
                                .product-name(data-i18n="food.butterIskender") Butter Iskender
                                    i.icon-info.ml-1
                            .product-price 10.00 TL
                        .bill-order-content-item.odendi
                            .d-flex
                                .product-count 2
                                .product-name(data-i18n="food.butterIskender") Butter Iskender
                            .product-price 20.00 TL
                        .divider.divider--small
                        .bill-order-content-item.secildi
                            .d-flex
                                .product-count 2
                                .product-name(data-i18n="food.water") Water
                            .product-price 5.00 TL
                            .secildi-text(data-i18n="bill.allSelected") All Selected
                                include secildi_buttons
                        .bill-order-content-footer
                            .title(data-i18n="common.total") Total
                            .amount 122.22 TL

                .bill-order-content
                    .bill-order-content-header
                        .bill-order-content__title(data-i18n="bill.orderNo") Order No: #258
                        .button.button--sm.button--gray(data-i18n="bill.paid") Paid
                    .bill-order-content-items
                        .bill-order-content-item.odendi
                            .d-flex
                                .product-count 2
                                .product-name(data-i18n="food.water") Water
                            .product-price 5.00 TL
                        .divider.divider--small
                        .bill-order-content-item.odendi
                            .d-flex
                                .product-count 1
                                .product-name(data-i18n="food.cupOfTea") Cup of Tea
                            .product-price 4.00 TL
                .bill-order-content
                    .bill-order-content-header
                        .bill-order-content__title(data-i18n="bill.orderNo") Order No: #258
                        .button.button--sm.button--orange(data-i18n="bill.removeAll") Remove All
                    .bill-order-content-items
                        .bill-order-content-item.secildi
                            .d-flex
                                .product-count 2
                                .product-name(data-i18n="food.water") Water
                            .product-price 5.00 TL
                            .secildi-text(data-i18n="bill.allSelected") All Selected
                                include secildi_buttons
                        .divider.divider--small
                        .bill-order-content-item.secildi
                            .d-flex
                                .product-count 1
                                .product-name(data-i18n="food.cupOfTea") Cup of Tea
                            .product-price 4.00 TL
                            .secildi-text(data-i18n="bill.allSelected") All Selected
                                include secildi_buttons


                        .bill-order-content-footer
                            .title(data-i18n="common.total") Total
                            .amount 9.00 TL

        .apply-button.d-flex.mt-20
            .button.button--light
                span 542.00 TL
            .button.button--red.button--icon.button--icon--right(onclick='$("#odemeTuruSec").addClass("active")')
                span(data-i18n="bill.payBill") Pay Bill
                i.icon-arrow-right
