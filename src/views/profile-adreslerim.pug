extends blocks/layout
block vars
    - var index = true;

block append head
    title index
block append svg

block content
    .maincontainer
        .device-container
            .safearea
                .back.back-w-title
                    a(href="profile.html").back-item
                        i.icon-chevron-left
                    .title(data-i18n="addresses.title") My Addresses
                .within_back_area
                    .profile
                        .profile-content
                            .form-content
                                .profile-content__title
                                    i.icon-map-pin.mr-2
                                    span(data-i18n="addresses.locationSelection") LOCATION SELECTION
                                .profile-content-info.mt-0
                                    span(data-i18n="addresses.locationDesc") When your location is off, we will search based on the location you selected.
                                .divider.divider--small
                                .adres
                                    .button.button--outline-red.button--icon.button--icon--left.mb-20
                                        i.icon-gps_fixed
                                        span(data-i18n="addresses.findMyLocation") Find My Location
                                    .title.text-left.mb-10(data-i18n="addresses.savedAddresses") Saved Addresses
                                    label.radio.w-100.adres-item
                                        .radio__content
                                            .adres-item__title.radio__title
                                                | Çankaya / Ankara
                                        input.radio__input(type='radio' name="adres" checked='')
                                        span.radio__toggle
                                    label.radio.w-100.adres-item
                                        .radio__content
                                            .adres-item__title.radio__title
                                                | Çankaya / Ankara
                                        input.radio__input(type='radio' name="adres" checked='')
                                        span.radio__toggle






